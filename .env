# === Orchestrateur ===
ORCHESTRATEUR_API_KEY=dev_orchestrateur_key_change_me
BRIDGE_TOKEN=dev_bridge_token_change_me
# Symfony tourne sur le host:8000 - host.docker.internal le résout depuis le container
ORCHESTRATEUR_WEBHOOK_URL=http://host.docker.internal:8000/api/v1/internal/orchestrateur/webhook
ORCHESTRATEUR_WEBHOOK_SECRET=dev_orchestrateur_webhook_secret_change_me
# URL de base de l'API Symfony (pour le heartbeat bridge→API)
CENTRAL_API_URL=http://host.docker.internal:8000
CENTRAL_API_SECRET=dev_central_api_secret_local

# === MinIO (orchestrateur) ===
# Variable séparée de MINIO_ENDPOINT (utilisé par Symfony sur le host avec http://).
# minio-go attend host:port sans schéma.
ORCHESTRATEUR_MINIO_ENDPOINT=minio:9000
