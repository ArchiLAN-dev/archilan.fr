# Required
API_KEY=change_me
BRIDGE_TOKEN=shared_internal_token_for_bridge_instances

# HTTP
PORT=8000

# Port pool allocated to Bridge containers
PORT_RANGE_START=25000
PORT_RANGE_END=25099

# SQLite database path (inside the /data volume)
DB_PATH=/data/orchestrateur.db

# Docker
DOCKER_HOST=unix:///var/run/docker.sock
BRIDGE_IMAGE=archilan-bridge:latest
BRIDGE_NETWORK=archilan_default

# Webhook to API Symfony (optional)
WEBHOOK_URL=http://api/internal/orchestrateur/webhook
WEBHOOK_SECRET=change_me

# CORS — origins autorisées (séparées par virgule). * = tout autoriser (dev uniquement)
# Exemple prod : CORS_ORIGINS=https://archilan.fr,https://api.archilan.fr
CORS_ORIGINS=*

# Minio (S3) — fichiers apworld et yamls de session
# Laisser MINIO_ENDPOINT vide pour désactiver (les fichiers ne seront pas pré-chargés dans le container)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_APWORLDS=apworlds
MINIO_BUCKET_SESSIONS=sessions
