# Required
API_KEY=change_me
BRIDGE_TOKEN=shared_internal_token_for_bridge_instances

# HTTP
PORT=8000

# Port pool allocated to Bridge containers
PORT_RANGE_START=25000
PORT_RANGE_END=25099

# SQLite database path (inside the /data volume)
DB_PATH=/data/orchestrateur.db

# Docker
DOCKER_HOST=unix:///var/run/docker.sock
BRIDGE_IMAGE=archilan-bridge:latest
BRIDGE_NETWORK=archilan_default

# Webhook to API Symfony (optional)
WEBHOOK_URL=http://api/internal/orchestrateur/webhook
WEBHOOK_SECRET=change_me
