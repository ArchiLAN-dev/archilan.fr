{
    "swagger": "2.0",
    "info": {
        "description": "Gestion des containers Bridge Archipelago — création, arrêt, suppression et monitoring.",
        "title": "Archilan Orchestrateur API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/",
    "paths": {
        "/apworlds": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Stores the apworld in Minio, runs a one-shot Archipelago container to generate\nthe default YAML template, stores it, and returns both the hash and the YAML.",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "apworlds"
                ],
                "summary": "Upload an apworld and generate its YAML template",
                "parameters": [
                    {
                        "type": "file",
                        "description": "The .apworld file",
                        "name": "file",
                        "in": "formData",
                        "required": true
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/api.UploadApworldResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/apworlds/{hash}/yaml": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Returns the default YAML template for the given apworld hash",
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "apworlds"
                ],
                "summary": "Get apworld default YAML template",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Apworld SHA-256 hash",
                        "name": "hash",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/containers": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Returns all managed Bridge containers",
