                        "type": "string"
                    }
                },
                "playerName": {
                    "type": "string"
                }
            }
        },
        "api.ContainerResponse": {
            "type": "object",
            "properties": {
                "containerId": {
                    "type": "string"
                },
                "createdAt": {
                    "type": "string"
                },
                "image": {
                    "type": "string"
                },
                "port": {
                    "type": "integer"
                },
                "sessionId": {
                    "type": "string"
                },
                "status": {
                    "description": "starting | running | stopped | crashed",
