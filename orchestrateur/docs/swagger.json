                "adminPassword": {
                    "description": "required",
                    "type": "string",
                    "example": "s3cr3t"
                },
                "serverPassword": {
                    "description": "optional — leave empty for open games",
                    "type": "string",
                    "example": ""
                },
                "sessionId": {
                    "type": "string",
                    "example": "weekly-run-2026-05-20"
                }
            }
        },
        "api.CreateContainerResponse": {
            "type": "object",
            "properties": {
                "port": {
                    "type": "integer",
                    "example": 25000
                },
                "sessionId": {
                    "type": "string",
                    "example": "weekly-run-2026-05-20"
                },
                "status": {
                    "type": "string",
                    "example": "starting"
                }
            }
        },
        "api.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string",
                    "example": "session not found"
                }
            }
        },
        "api.GenerateSessionRequest": {
            "type": "object",
            "properties": {
                "adminPassword": {
                    "type": "string"
                },
                "seed": {
                    "type": "string"
                }
            }
        },
        "api.HealthResponse": {
            "type": "object",
            "properties": {
                "status": {
                    "type": "string",
                    "example": "ok"
                }
            }
        },
        "api.LaunchSessionRequest": {
            "type": "object",
            "properties": {
                "adminPassword": {
                    "type": "string"
                },
                "serverPassword": {
                    "type": "string"
