# Frontend local development example.
# Copy to .env.local for local overrides. Do not commit .env.local.

# Public base URL used by the browser and generated links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Symfony API base URL used by frontend server/client code.
# Must be set at build time - this value is inlined in the client bundle by Next.js.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Optional Mercure hub URL for Server-Sent Events in local development.
NEXT_PUBLIC_MERCURE_PUBLIC_URL=http://localhost:3001/.well-known/mercure

# Twitch channel login to embed on the homepage live section.
NEXT_PUBLIC_TWITCH_CHANNEL_LOGIN=archilan

# Discord invite links surfaced in the UI (externalLinks).
NEXT_PUBLIC_ARCHIPELAGO_DISCORD_URL=https://discord.com/invite/8Z65BR2
NEXT_PUBLIC_ARCHILAN_DISCORD_URL=https://discord.gg/bVGmDcv2dE
