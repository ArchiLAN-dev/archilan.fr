ORCHESTRATEUR_WEBHOOK_SECRET=dev_orchestrateur_webhook_secret_change_me

TRAEFIK_TOKEN=change_me_traefik_token
WS_DOMAIN=ws.archilan.fr

MERCURE_URL=http://localhost:3001/.well-known/mercure
