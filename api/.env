MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_APWORLDS=apworlds
MINIO_BUCKET_SAVES=archipelago-saves
MINIO_BUCKET_MEDIA=media
MINIO_PRESIGN_TTL_SECONDS=3600

CENTRAL_API_SECRET=dev_central_api_secret_local
