DOCKER_HOST=tcp://localhost:2375
SYMFONY_INTERNAL_URL=http://host.docker.internal:8000
MERCURE_HUB_URL=http://host.docker.internal:3001/.well-known/mercure

ORCHESTRATEUR_API_KEY=dev_orchestrateur_key_change_me
BRIDGE_INTERNAL_TOKEN=dev_bridge_token_change_me

# Data-retention cleanup (story 13.7). Optional overrides — defaults applied in services.yaml.
# Grace (days) before a consumed email-confirmation / password-reset token is deleted.
#CLEANUP_TOKEN_CONSUMED_GRACE_DAYS=7
# Retention (days) for helloasso_sync_log rows (by attempt time).
#CLEANUP_HELLOASSO_SYNC_LOG_RETENTION_DAYS=90
# Retention (days) for event_private_access_log rows (by creation time).
#CLEANUP_EVENT_ACCESS_LOG_RETENTION_DAYS=365
