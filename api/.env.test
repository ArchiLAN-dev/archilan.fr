# Test environment - committed, non-secret CI values only.
# Loaded by Symfony Dotenv when APP_ENV=test (set by phpunit.xml.dist).
# Real secrets must never appear here; use .env.test.local (gitignored) for local overrides.
KERNEL_CLASS='App\Kernel'
APP_ENV=test
APP_SECRET='$ecretf0rt3st'
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_URL="sqlite:///%kernel.project_dir%/var/test.db"
MESSENGER_FAILED_TRANSPORT_DSN=in-memory://
MAILER_DSN=null://null
CENTRAL_API_SECRET=test-runner-secret
CENTRAL_API_URL=http://localhost:8000
RUNNER_ID=test-runner
PORT_RANGE_START=38281
PORT_RANGE_END=38290
WORKSPACE_DIR=/tmp/archilan-test-workspace
ARCHIVE_DIR=/tmp/archilan-test-archives
ARCHIPELAGO_GENERATE_IMAGE=archipelago-generate
ARCHIPELAGO_SERVER_IMAGE=archipelago-server
TRAEFIK_TOKEN=test-traefik-token
WS_DOMAIN=ws.archilan.fr
MERCURE_URL=http://example.com/.well-known/mercure
MERCURE_PUBLIC_URL=http://example.com/.well-known/mercure
MERCURE_JWT_SECRET=dev_mercure_jwt_secret_change_in_production
# JWT keys are not configured here - only required when authentication tests are written.
# Generate RSA test keys and add JWT_SECRET_KEY / JWT_PUBLIC_KEY / JWT_PASSPHRASE at that point.
