# =============================================================================
# archilan.fr - Variables de production
# Copier en .env sur le serveur, ne jamais commiter ce fichier rempli.
# =============================================================================

# ─── Domaines (Traefik) ──────────────────────────────────────────────────────
FRONTEND_DOMAIN=archilan.fr
API_DOMAIN=api.archilan.fr
ORCHESTRATEUR_DOMAIN=orchestrateur.archilan.fr
MERCURE_DOMAIN=mercure.archilan.fr
FRONTEND_ORIGIN=https://archilan.fr
DEFAULT_URI=https://api.archilan.fr
NEXT_PUBLIC_API_BASE_URL=https://api.archilan.fr
RUNNER_PUBLIC_HOST=orchestrateur.archilan.fr

# ─── Symfony ─────────────────────────────────────────────────────────────────
APP_SECRET=                        # php -r "echo bin2hex(random_bytes(32));"
EMAIL_HASH_SECRET=                 # php -r "echo bin2hex(random_bytes(32));"
JWT_PASSPHRASE=                    # openssl rand -hex 32

# ─── Base de données ─────────────────────────────────────────────────────────
POSTGRES_DB=archilan
POSTGRES_USER=archilan
POSTGRES_PASSWORD=                 # openssl rand -hex 24

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_USER=archilan
RABBITMQ_PASSWORD=                 # openssl rand -hex 24

# ─── MinIO ───────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=archilan-minio
MINIO_ROOT_PASSWORD=               # openssl rand -hex 24
MINIO_PRESIGN_ENDPOINT=https://minio.archilan.fr
MINIO_BUCKET_APWORLDS=apworlds
MINIO_BUCKET_SAVES=sessions
MINIO_BUCKET_MEDIA=media

# ─── Mercure ─────────────────────────────────────────────────────────────────
MERCURE_JWT_SECRET=                # openssl rand -hex 32
MERCURE_PUBLIC_URL=https://mercure.archilan.fr/.well-known/mercure

# ─── Orchestrateur ───────────────────────────────────────────────────────────
ORCHESTRATEUR_API_KEY=             # openssl rand -hex 32
ORCHESTRATEUR_WEBHOOK_SECRET=      # openssl rand -hex 32
CENTRAL_API_SECRET=                # openssl rand -hex 32
BRIDGE_INTERNAL_TOKEN=             # openssl rand -hex 32
PORT_RANGE_START=25000
PORT_RANGE_END=25099
BRIDGE_IMAGE=ghcr.io/archilan-dev/bridge:latest
AP_IMAGE=ghcr.io/archilan-dev/archipelago:latest
ARCHIPELAGO_GENERATE_IMAGE=ghcr.io/archilan-dev/archipelago:latest
AP_SERVER_PORT_OFFSET=10000

# ─── Mailer ──────────────────────────────────────────────────────────────────
MAILER_DSN=smtp://user:password@smtp.example.com:587
MAILER_SENDER=noreply@archilan.fr

# ─── Discord ─────────────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ROLE_ID_ADMIN=
DISCORD_ROLE_ID_MEMBER=
DISCORD_REDIRECT_URI_AUTH=https://api.archilan.fr/api/v1/auth/discord/callback
DISCORD_REDIRECT_URI_LINK=https://api.archilan.fr/api/v1/account/discord/link/callback

# ─── Twitch ──────────────────────────────────────────────────────────────────
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_CHANNEL_LOGIN=archilan

# ─── HelloAsso ───────────────────────────────────────────────────────────────
HELLOASSO_CLIENT_ID=
HELLOASSO_CLIENT_SECRET=
HELLOASSO_ORGANIZATION_SLUG=
HELLOASSO_MEMBERSHIP_FORM_SLUG=
HELLOASSO_SHOP_FORM_SLUG=

# ─── Docker socket ───────────────────────────────────────────────────────────
DOCKER_GID=           # getent group docker | cut -d: -f3

# ─── Traefik / infra ─────────────────────────────────────────────────────────
TRAEFIK_TOKEN=                     # token de l'API Traefik si activé
WS_DOMAIN=ws.archilan.fr
CORS_ORIGINS=https://archilan.fr
