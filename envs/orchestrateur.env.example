API_KEY=                           # même valeur que ORCHESTRATEUR_API_KEY
BRIDGE_TOKEN=                      # même valeur que BRIDGE_INTERNAL_TOKEN
PORT_RANGE_START=25000
PORT_RANGE_END=25099
DB_PATH=/data/orchestrateur.db
DOCKER_HOST=unix:///var/run/docker.sock
BRIDGE_IMAGE=ghcr.io/archilan-dev/bridge:latest
BRIDGE_NETWORK=archilan-prod_default
WEBHOOK_URL=http://api-web/api/v1/internal/orchestrateur/webhook
WEBHOOK_SECRET=                    # même valeur que ORCHESTRATEUR_WEBHOOK_SECRET
CENTRAL_API_URL=http://api-web
CENTRAL_API_SECRET=                # même valeur que CENTRAL_API_SECRET
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=archilan-minio
MINIO_SECRET_KEY=                  # même valeur que MINIO_ROOT_PASSWORD
MINIO_USE_SSL=false
MINIO_BUCKET_APWORLDS=apworlds
MINIO_BUCKET_SESSIONS=sessions
AP_IMAGE=ghcr.io/archilan-dev/archipelago:latest
AP_SERVER_PORT_OFFSET=10000
CORS_ORIGINS=https://archilan.fr
