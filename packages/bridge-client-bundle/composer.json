{
    "name": "archilan/bridge-client-bundle",
    "description": "Symfony bundle — autoconfigures the Archilan bridge WebSocket dispatcher.",
    "type": "symfony-bundle",
    "license": "proprietary",
    "repositories": [
        {
            "type": "path",
            "url": "../bridge-client"
        }
    ],
    "require": {
        "php": "^8.2",
        "archilan/bridge-client": "*",
        "symfony/config": "^6.4|^7.0",
        "symfony/console": "^6.4|^7.0",
        "symfony/dependency-injection": "^6.4|^7.0",
        "symfony/http-kernel": "^6.4|^7.0"
    },
    "autoload": {
        "psr-4": {
            "Archilan\\BridgeClientBundle\\": "src/"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "symfony/http-client": "^6.4|^7.0",
        "symfony/http-client-contracts": "^3.0"
    },
    "config": {
        "sort-packages": true
    }
}
