{
    "name": "archilan/bridge-client-bundle-test",
    "description": "Sandbox for testing the Archilan bridge Symfony bundle.",
    "type": "project",
    "license": "proprietary",
    "repositories": [
        {
            "type": "path",
            "url": "../bridge-client"
        },
        {
            "type": "path",
            "url": "../bridge-client-bundle"
        }
    ],
    "require": {
        "php": "^8.2",
        "archilan/bridge-client-bundle": "*",
        "symfony/dotenv": "^7.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/http-client": "^7.0",
        "symfony/yaml": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
